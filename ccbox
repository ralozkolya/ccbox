#!/usr/bin/env bash
#
# ccbox — run Claude Code in a rootless podman container.
#
#   ccbox build          Build the image (pass --no-cache to bypass the cache).
#   ccbox update         Update Claude Code only (no full rebuild).
#   ccbox auth           One-time logins (gh, gcloud, claude, MCP, SSH key).
#   ccbox [run]          Run Claude Code (default).
#   ccbox auto           Run Claude Code in auto mode (--permission-mode auto).
#   ccbox shell          Run a bash shell against $PWD.
#   ccbox help           Show usage (run `ccbox help` for full details).
#
# Host boundary (req #3): the ONLY host bind mount is the current directory.
# All credentials live in the named volume "ccbox-home", never on the host.
#
# Platform access: set CCBOX_NET to your platform's podman network (e.g.
# "<compose-project>_default") to join it and reach services by name.
#
set -euo pipefail

IMAGE="${CCBOX_IMAGE:-ccbox:latest}"
VOLUME="${CCBOX_VOLUME:-ccbox-home}"
NET="${CCBOX_NET:-podman}"   # default rootless network = outbound only
HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

engine() {
  command -v podman >/dev/null || { echo "podman not found" >&2; exit 1; }

  # Rootful podman ignores --userns=keep-id, so the workspace keeps its host
  # uid while the container runs as node: git sees "dubious ownership" on every
  # repo under /workspace, and the mount isn't writable.
  if [ "$(podman info --format '{{.Host.Security.Rootless}}' 2>/dev/null)" = "false" ]; then
    echo "ccbox: podman is running rootful; ccbox needs rootless." >&2
    echo "Pick the non-root connection, e.g.:" >&2
    echo "  podman system connection default podman-machine-default" >&2
    echo "(check names with 'podman system connection list'; the root one ends" >&2
    echo " in '-root'.) Images are per-connection, so re-run 'ccbox build'." >&2
    exit 1
  fi
}

# Shared run flags. Only $PWD crosses the host boundary; the home volume is
# podman-managed storage, not a host path.
#
# Git worktrees: launch ccbox from the main repo root (not from inside a
# worktree dir) so the repo — including worktrees nested under it, e.g.
# .claude/worktrees/<name> — is mounted as a unit at /workspace. The bundled
# git defaults to worktree.useRelativePaths, so worktrees created in the
# container record relative links and resolve both here and on the host.
run_flags() {
  # Pin the host user to container uid/gid 1000 (the "node" user) regardless
  # of the host's own uid, so files written into the workspace stay owned by
  # you on any machine.
  #
  # The workspace uses :z (shared SELinux label), not :Z (private). Under
  # enforcing SELinux, :Z relabels the workspace with a per-container MCS
  # category pair that's exclusive to one container; a second ccbox mounting
  # the same tree (or a nested worktree) relabels it again, and the first
  # instance loses access to its own workspace. :z applies a shared label so
  # concurrent instances on the same repo can coexist.
  # Not on macOS: virtiofs stores no SELinux xattrs, so the relabel walk is
  # pure cost — on a large repo it pegs the VM until it stops responding.
  local relabel=""
  if [ "$(uname -s)" = Linux ] && [ -d /sys/fs/selinux ]; then
    relabel=":z"
  fi

  printf '%s\n' \
    --rm -it \
    --userns=keep-id:uid=1000,gid=1000 \
    --network "$NET" \
    -v "$PWD":/workspace"$relabel" \
    -v "$VOLUME":/home/node \
    -w /workspace
}

# Populate the global FLAGS array from run_flags. Portable stand-in for
# `mapfile -t FLAGS < <(run_flags)`: macOS ships bash 3.2, which predates the
# mapfile/readarray builtin, so that fails with "mapfile: command not found".
load_flags() {
  FLAGS=()
  while IFS= read -r line; do
    FLAGS+=("$line")
  done < <(run_flags)
}

cmd_help() {
  cat <<'EOF'
ccbox — run Claude Code in a rootless podman container.

Usage:
  ccbox build [args]   Build the image. Extra args pass to `podman build`,
                       e.g. `ccbox build --no-cache` to bypass the layer cache.
  ccbox update [ver]   Update Claude Code to the latest release (or to [ver]).
                       Rebuilds only the Claude Code layer — seconds, not a
                       full image rebuild.
  ccbox auth           One-time logins (gh, gcloud, claude, MCP, SSH key).
  ccbox [run] [args]   Run Claude Code (default). Extra args pass to claude.
  ccbox auto [args]    Run Claude Code in auto mode (--permission-mode auto).
                       Extra args pass to claude.
  ccbox shell          Open a bash shell against $PWD.
  ccbox help           Show this help.

Environment:
  CCBOX_IMAGE   Image tag         (default: ccbox:latest)
  CCBOX_VOLUME  Home volume name  (default: ccbox-home)
  CCBOX_NET     Podman network    (default: podman)

Only the current directory is bind-mounted; credentials live in the
named volume (default "ccbox-home"), never on the host.
EOF
}

cmd_build() {
  engine
  # Extra args pass through to `podman build`, e.g. `ccbox build --no-cache`
  # to bypass the layer cache for a clean rebuild.
  podman build "$@" -t "$IMAGE" "$HERE"
}

# Update Claude Code without a full rebuild.
#
# Claude Code's own updater can't run here — npm's global dir is root-owned and
# the container runs as node, so it fails with "no_permissions" and the image
# stays pinned to whatever it was built with. Instead, resolve the wanted
# version and pass it as CC_VERSION: only that RUN layer (and the trivial COPYs
# after it) is invalidated, so the tools layer — git built from source — is
# reused. Already on the latest? The build-arg is unchanged, the layer cache
# hits, and this is a no-op.
cmd_update() {
  engine
  local want="${1:-}"
  if [ -z "$want" ]; then
    echo "Resolving latest @anthropic-ai/claude-code ..."
    want="$(podman run --rm "$IMAGE" npm view @anthropic-ai/claude-code version | tr -d '[:space:]')"
  fi
  case "$want" in
    [0-9]*.[0-9]*.[0-9]*) ;;
    *) echo "not a valid version: '$want'" >&2; exit 1 ;;
  esac

  echo "Building $IMAGE with Claude Code $want ..."
  podman build --build-arg "CC_VERSION=$want" -t "$IMAGE" "$HERE"
  podman run --rm "$IMAGE" claude --version
}

# First-run setup: drop into a shell with guidance, register the MCP server,
# and generate a dedicated SSH key inside the volume if missing.
cmd_auth() {
  engine
  load_flags
  podman run "${FLAGS[@]}" "$IMAGE" bash -lc '
    set -e

    # Register the Atlassian remote MCP server (idempotent).
    if ! claude mcp list 2>/dev/null | grep -q "^atlassian"; then
      claude mcp add-json --scope user atlassian "$(cat /etc/ccbox/mcp-atlassian.json)" || true
    fi

    # Dedicated SSH key in the persisted volume — host ~/.ssh is never used.
    mkdir -p ~/.ssh && chmod 700 ~/.ssh
    if [ ! -f ~/.ssh/id_ed25519 ]; then
      ssh-keygen -t ed25519 -N "" -f ~/.ssh/id_ed25519 -C "ccbox-agent"
      [ -f ~/.ssh/config ] || printf "Host *\n  AddKeysToAgent yes\n" > ~/.ssh/config
      chmod 600 ~/.ssh/config
    fi

    echo
    echo "=== ccbox first-run setup ==="
    echo "Run these once; everything persists in the ccbox-home volume:"
    echo "  gh auth login"
    echo "  gcloud auth login --no-launch-browser"
    echo "  claude            # sign in to your subscription, then /exit"
    echo "  (run any Atlassian query in claude once to complete its OAuth)"
    echo
    echo "Add this SSH public key to GitHub / your git hosts:"
    echo "-----------------------------------------------------------------"
    cat ~/.ssh/id_ed25519.pub
    echo "-----------------------------------------------------------------"
    echo
    exec bash -l
  '
}

cmd_run() {
  engine
  load_flags
  podman run "${FLAGS[@]}" "$IMAGE" claude "$@"
}

cmd_auto() {
  engine
  load_flags
  podman run "${FLAGS[@]}" "$IMAGE" claude --permission-mode auto "$@"
}

cmd_shell() {
  engine
  load_flags
  podman run "${FLAGS[@]}" "$IMAGE" bash -l
}

case "${1:-run}" in
  build)            shift; cmd_build "$@" ;;
  update)           shift; cmd_update "$@" ;;
  auth)             shift; cmd_auth "$@" ;;
  auto)             shift; cmd_auto "$@" ;;
  shell)            shift; cmd_shell "$@" ;;
  run)              shift; cmd_run "$@" ;;
  help|-h|--help)   cmd_help ;;
  *)                cmd_run "$@" ;;   # treat unknown args as claude args
esac
